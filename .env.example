# =============================================
# RESTAURA 4K — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# Na Vercel, configure estas variáveis em:
# Project Settings → Environment Variables

# --- Google Gemini AI ---
# Obtenha em: https://aistudio.google.com/app/apikey
# ATENÇÃO: Use o prefixo VITE_ para que o Vite exponha para o frontend
VITE_GEMINI_API_KEY="SUA_GEMINI_API_KEY_AQUI"

# --- Supabase ---
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY_AQUI"

# --- URL da Aplicação ---
# Em produção, use a URL da Vercel (ex: https://restaura4k.vercel.app)
APP_URL="http://localhost:3000"
